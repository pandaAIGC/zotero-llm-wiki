# ============================================================
# Zotero LLM Wiki - API 配置示例
# 复制为 .env 后填写；不要提交真实 .env
# ============================================================

# Zotero Web API（必填）
ZOTERO_USER_ID=
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user

# Zotero 本地 storage 路径（可选；按自己的机器修改）
ZOTERO_LOCAL_STORAGE=

# Zotero 本地 SQLite 路径（可选；Obsidian wiki 只读元数据时使用）
ZOTERO_SQLITE=

# Obsidian LLM Wiki 输出目录（可选）
ZOTERO_LLM_WIKI_DIR=

# MinerU（必填 - PDF 解析）
MINERU_TOKEN=
MINERU_MODEL=vlm
MINERU_HTTP_TIMEOUT=600.0
MIN_PARSED_CACHE_CHARS=500

# 已确认解析失败/空结果的 PDF，达到次数后跳过，避免重复消耗 MinerU/embedding 资源。
# 设为 0 可关闭该保护。
PARSE_FAILURE_MAX_ATTEMPTS=2

# 文本向量化 provider: zhipu 或 ollama
# zhipu 使用智谱 embedding-3，默认写入 data/chroma_db
# ollama 使用本地 Ollama，默认按模型名写入独立 ChromaDB
EMBED_PROVIDER=zhipu

# 智谱 BigModel（EMBED_PROVIDER=zhipu 时需要）
ZHIPU_API_KEY=
ZHIPU_MAX_BATCH=8
ZHIPU_BATCH_SLEEP_SECONDS=2.0
ZHIPU_RETRY_BASE_SECONDS=3.0

# Ollama local embedding（EMBED_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:latest
OLLAMA_MAX_BATCH=8
OLLAMA_MAX_CHARS=6000
OLLAMA_BATCH_SLEEP_SECONDS=0.0

# 可选：手动指定 ChromaDB 目录。一般不要设置，provider 会自动分库。
CHROMA_DIR=

# Open Access PDF / 学术搜索（可选）
UNPAYWALL_EMAIL=
OPENALEX_EMAIL=
CORE_API_KEY=
